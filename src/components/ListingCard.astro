---
import { Image } from 'astro:assets';

interface Props {
  name: string;
  neighborhood: string;
  googleRating?: number;
  googleReviewCount?: number;
  priceIndicator?: string;
  slug: string;
  category: 'nails' | 'massage';
  lang?: string;
}

const { name, neighborhood, googleRating, googleReviewCount, priceIndicator, slug, category, lang = 'es' } = Astro.props;
const categoryPath = lang === 'es' ? category : `en/${category}`;
const stars = googleRating ? Math.round(googleRating) : 0;
const ratingLabel = lang === 'es' ? 'valoración' : 'rating';
const reviewsLabel = lang === 'es' ? 'reseñas' : 'reviews';
const accentColor = category === 'nails' ? 'var(--color-accent-nails)' : 'var(--color-accent-massage)';
---

<a href={`/${categoryPath}/${slug}`} class="group block bg-white rounded-xl border border-stone-200 hover:border-stone-300 hover:shadow-sm transition-all p-5">
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0">
      <h3 class="font-semibold text-stone-900 group-hover:text-stone-700 transition-colors truncate">
        {name}
      </h3>
      <p class="text-sm text-stone-500 mt-0.5">{neighborhood}</p>
    </div>
    {priceIndicator && (
      <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-stone-100 text-stone-600 shrink-0">
        {priceIndicator}
      </span>
    )}
  </div>

  <div class="flex items-center gap-2 mt-3">
    {googleRating && (
      <>
        <div class="flex items-center gap-0.5">
          {[1, 2, 3, 4, 5].map(i => (
            <svg
              class={`w-4 h-4 ${i <= stars ? 'text-amber-400' : 'text-stone-200'}`}
              fill="currentColor"
              viewBox="0 0 20 20"
            >
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>
        <span class="text-sm font-medium text-stone-700">{googleRating}</span>
        <span class="text-xs text-stone-400">({googleReviewCount} {reviewsLabel})</span>
      </>
    )}
  </div>
</a>
