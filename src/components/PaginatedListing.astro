---
import FilterBar from './FilterBar.astro';

interface Props {
  businesses: any[];
  category: string;
  lang: 'es' | 'en';
  total: number;
  currentPage: number;
  totalPages: number;
}

const { businesses, category, lang, total, currentPage, totalPages } = Astro.props;

const isSpanish = lang === 'es';
const detailPath = (slug: string) => lang === 'es' ? `/${category}/${slug}` : `/en/${category}/${slug}`;
const indexUrl = lang === 'es' ? `/${category}/` : `/en/${category}/`;
const pageUrl = (n: number) => lang === 'es' ? `/${category}/page/${n}/` : `/en/${category}/page/${n}/`;

const labels = isSpanish ? {
  previous: '← Anterior',
  next: 'Siguiente →',
  noResults: 'No hay resultados que coincidan con estos filtros',
  noResultsHint: 'Prueba con otros criterios o navega a otra página',
} : {
  previous: '← Previous',
  next: 'Next →',
  noResults: 'No results match these filters',
  noResultsHint: 'Try other criteria or browse another page',
};
---

<div class="mt-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4" id="listing-grid">
  {businesses.map(business => (
    <a href={detailPath(business.id)}
      class="listing-card group block bg-white rounded-xl border border-stone-200 hover:border-stone-300 hover:shadow-sm transition-all overflow-hidden"
      data-neighborhood={business.data.neighborhood}
      data-price={business.data.priceIndicator || ''}
      data-rating={business.data.googleRating?.toString() || '0'}
      data-reviews={business.data.googleReviewCount?.toString() || '0'}
    >
      <img
        src={`/images/${category}/${business.id}-0.jpg`}
        alt={business.data.name}
        class="w-full h-44 object-cover"
        loading="lazy"
        decoding="async"
        onerror="this.style.display='none'"
      />
      <div class="p-5">
        <div class="flex items-start justify-between gap-2">
          <h3 class="font-semibold text-stone-900 group-hover:text-stone-700 text-sm truncate">{business.data.name}</h3>
          {business.data.priceIndicator && (
            <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-stone-100 text-stone-600 shrink-0">{business.data.priceIndicator}</span>
          )}
        </div>
        <p class="text-xs text-stone-500 mt-0.5">{business.data.neighborhood}</p>
        {business.data.googleRating && (
          <div class="flex items-center gap-1.5 mt-2">
            <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
            <span class="text-xs font-medium text-stone-700">{business.data.googleRating}</span>
            <span class="text-xs text-stone-400">({business.data.googleReviewCount})</span>
          </div>
        )}
        {business.data.services && business.data.services.length > 0 && (
          <div class="mt-2 flex flex-wrap gap-1">
            {business.data.services.slice(0, 3).map(s => (
              <span class="text-xs px-2 py-0.5 rounded-full bg-stone-50 text-stone-500 border border-stone-100">{typeof s === 'string' ? s : s.name}</span>
            ))}
          </div>
        )}
      </div>
    </a>
  ))}
</div>

<div id="no-results" class="hidden mt-8 text-center py-12 bg-stone-50 rounded-xl border border-stone-200">
  <p class="text-stone-500 text-lg">{labels.noResults}</p>
  <p class="text-stone-400 text-sm mt-1">{labels.noResultsHint}</p>
</div>

{totalPages > 1 && (
  <nav class="mt-10 flex items-center justify-center gap-1" aria-label={isSpanish ? 'Paginación' : 'Pagination'}>
    {currentPage > 1 ? (
      <a href={currentPage === 2 ? indexUrl : pageUrl(currentPage - 1)} class="px-3 py-2 text-sm text-stone-600 hover:text-stone-900 hover:bg-stone-100 rounded-lg transition-colors">{labels.previous}</a>
    ) : (
      <span class="px-3 py-2 text-sm text-stone-300 cursor-not-allowed">{labels.previous}</span>
    )}
    <div class="flex gap-1">
      {Array.from({ length: totalPages }, (_, i) => {
        const n = i + 1;
        const url = n === 1 ? indexUrl : pageUrl(n);
        const isCurrent = n === currentPage;
        return (
          <a href={url}
            class={`px-3 py-2 text-sm rounded-lg transition-colors ${isCurrent ? 'bg-stone-900 text-white font-medium' : 'text-stone-600 hover:bg-stone-100 hover:text-stone-900'}`}
            aria-current={isCurrent ? 'page' : undefined}>
            {n}
          </a>
        );
      })}
    </div>
    {currentPage < totalPages ? (
      <a href={pageUrl(currentPage + 1)} class="px-3 py-2 text-sm text-stone-600 hover:text-stone-900 hover:bg-stone-100 rounded-lg transition-colors">{labels.next}</a>
    ) : (
      <span class="px-3 py-2 text-sm text-stone-300 cursor-not-allowed">{labels.next}</span>
    )}
  </nav>
)}

<script>
  function filterCards() {
    var form = document.getElementById('filters');
    if (!form) return;
    var sort = form.querySelector('[name="sort"]');
    var neighborhood = form.querySelector('[name="neighborhood"]');
    var price = form.querySelector('[name="price"]');
    var sortVal = sort ? sort.value : 'rating';
    var neighborhoodVal = neighborhood ? neighborhood.value : '';
    var priceVal = price ? price.value : '';
    var cards = Array.from(document.querySelectorAll('.listing-card'));
    var grid = document.getElementById('listing-grid');
    var noResults = document.getElementById('no-results');
    var visible = cards.filter(function(card) {
      if (neighborhoodVal && card.dataset.neighborhood !== neighborhoodVal) return false;
      if (priceVal && card.dataset.price !== priceVal) return false;
      return true;
    });
    visible.sort(function(a, b) {
      var ra = parseFloat(a.dataset.rating || '0');
      var rb = parseFloat(b.dataset.rating || '0');
      var ca = parseInt(a.dataset.reviews || '0');
      var cb = parseInt(b.dataset.reviews || '0');
      var pa = a.dataset.price || '';
      var pb = b.dataset.price || '';
      switch (sortVal) {
        case 'rating': return rb - ra || cb - ca;
        case 'reviews': return cb - ca;
        case 'price_asc': return pa.length - pb.length || (pa < pb ? -1 : pa > pb ? 1 : 0);
        case 'price_desc': return pb.length - pa.length || (pb < pa ? -1 : pa > pb ? 1 : 0);
        default: return 0;
      }
    });
    grid.innerHTML = '';
    if (visible.length === 0) {
      if (noResults) noResults.classList.remove('hidden');
    } else {
      if (noResults) noResults.classList.add('hidden');
      visible.forEach(function(card) { grid.appendChild(card); });
    }
  }
  document.getElementById('filters')?.addEventListener('change', filterCards);
</script>
