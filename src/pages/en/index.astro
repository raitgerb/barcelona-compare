---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { imageUrl } from '../../lib/images';

const nails = await getCollection('nails');
const massage = await getCollection('massage');

const featuredNails = nails.filter(b => b.data.googleRating && b.data.googleRating >= 4.6).sort((a, b) => (b.data.googleReviewCount || 0) - (a.data.googleReviewCount || 0)).slice(0, 4);
const featuredMassage = massage.filter(b => b.data.googleRating && b.data.googleRating >= 4.6).sort((a, b) => (b.data.googleReviewCount || 0) - (a.data.googleReviewCount || 0)).slice(0, 4);
---

<BaseLayout
  title="Find the best of Barcelona"
  description="Compare nail salons and massage centers in Barcelona. Prices, services, and ratings in one place."
  lang="en"
>
  <section class="bg-gradient-to-b from-brand-50 to-white">
    <div class="max-w-6xl mx-auto px-4 py-16 md:py-24 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-stone-900 tracking-tight leading-tight">
        Find the best of<br class="hidden sm:block" /> Barcelona
      </h1>
      <p class="mt-4 text-lg text-stone-500 max-w-xl mx-auto">
        Compare prices, services, and ratings in one place
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/en/nails" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-accent-nails text-white font-medium hover:opacity-90 transition-opacity text-sm">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
          Nail salons
        </a>
        <a href="/en/massage" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-accent-massage text-white font-medium hover:opacity-90 transition-opacity text-sm">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
          Massage centers
        </a>
      </div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 py-16">
    <div class="flex items-end justify-between mb-8">
      <div>
        <h2 class="text-2xl font-bold text-stone-900">Barcelona's best nail salons</h2>
        <p class="text-stone-500 mt-1">Compare prices, techniques, and ratings by neighborhood</p>
      </div>
      <a href="/en/nails" class="text-sm font-medium text-accent-nails hover:underline shrink-0">View all →</a>
    </div>
    {featuredNails.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {featuredNails.map(business => (
          <a href={`/en/nails/${business.id}`} class="group block bg-white rounded-xl border border-stone-200 hover:border-stone-300 hover:shadow-sm transition-all overflow-hidden">
            <img
              src={imageUrl('nails', business.id, 0)}
              alt={business.data.name}
              class="w-full h-40 object-cover"
              loading="lazy"
              onerror="this.style.display='none'"
            />
            <div class="p-5">
            <div class="flex items-start justify-between gap-2">
              <h3 class="font-semibold text-stone-900 group-hover:text-stone-700 text-sm truncate">{business.data.name}</h3>
              {business.data.priceIndicator && (
                <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-stone-100 text-stone-600 shrink-0">{business.data.priceIndicator}</span>
              )}
            </div>
            <p class="text-xs text-stone-500 mt-0.5">{business.data.neighborhood}</p>
            {business.data.googleRating && (
              <div class="flex items-center gap-1.5 mt-2">
                <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                <span class="text-xs font-medium text-stone-700">{business.data.googleRating}</span>
                <span class="text-xs text-stone-400">({business.data.googleReviewCount})</span>
              </div>
            )}
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="bg-stone-50 rounded-xl border border-stone-200 p-8 text-center">
        <p class="text-stone-400">Coming soon: Barcelona's best nail salons.</p>
      </div>
    )}
  </section>

  <section class="max-w-6xl mx-auto px-4 py-16 bg-stone-50/50">
    <div class="flex items-end justify-between mb-8">
      <div>
        <h2 class="text-2xl font-bold text-stone-900">Barcelona's best massages</h2>
        <p class="text-stone-500 mt-1">Compare massage types, prices, and centers</p>
      </div>
      <a href="/en/massage" class="text-sm font-medium text-accent-massage hover:underline shrink-0">View all →</a>
    </div>
    {featuredMassage.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {featuredMassage.map(business => (
          <a href={`/en/massage/${business.id}`} class="group block bg-white rounded-xl border border-stone-200 hover:border-stone-300 hover:shadow-sm transition-all overflow-hidden">
            <img
              src={imageUrl('massage', business.id, 0)}
              alt={business.data.name}
              class="w-full h-40 object-cover"
              loading="lazy"
              onerror="this.style.display='none'"
            />
            <div class="p-5">
            <div class="flex items-start justify-between gap-2">
              <h3 class="font-semibold text-stone-900 group-hover:text-stone-700 text-sm truncate">{business.data.name}</h3>
              {business.data.priceIndicator && (
                <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-stone-100 text-stone-600 shrink-0">{business.data.priceIndicator}</span>
              )}
            </div>
            <p class="text-xs text-stone-500 mt-0.5">{business.data.neighborhood}</p>
            {business.data.googleRating && (
              <div class="flex items-center gap-1.5 mt-2">
                <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                <span class="text-xs font-medium text-stone-700">{business.data.googleRating}</span>
                <span class="text-xs text-stone-400">({business.data.googleReviewCount})</span>
              </div>
            )}
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="bg-white rounded-xl border border-stone-200 p-8 text-center">
        <p class="text-stone-400">Coming soon: Barcelona's best massage centers.</p>
      </div>
    )}
  </section>

  <section class="max-w-6xl mx-auto px-4 py-16">
    <h2 class="text-2xl font-bold text-stone-900 text-center mb-12">How it works</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-3xl mx-auto">
      <div class="text-center">
        <div class="w-12 h-12 rounded-full bg-brand-100 text-brand-600 flex items-center justify-center mx-auto mb-4 font-bold text-lg">1</div>
        <h3 class="font-semibold text-stone-900 mb-2">Search</h3>
        <p class="text-sm text-stone-500">Find businesses by category, neighborhood, or price</p>
      </div>
      <div class="text-center">
        <div class="w-12 h-12 rounded-full bg-brand-100 text-brand-600 flex items-center justify-center mx-auto mb-4 font-bold text-lg">2</div>
        <h3 class="font-semibold text-stone-900 mb-2">Compare</h3>
        <p class="text-sm text-stone-500">Google ratings, prices, services, and languages in one place</p>
      </div>
      <div class="text-center">
        <div class="w-12 h-12 rounded-full bg-brand-100 text-brand-600 flex items-center justify-center mx-auto mb-4 font-bold text-lg">3</div>
        <h3 class="font-semibold text-stone-900 mb-2">Choose</h3>
        <p class="text-sm text-stone-500">Contact directly via WhatsApp, phone, or website</p>
      </div>
    </div>
  </section>
</BaseLayout>
