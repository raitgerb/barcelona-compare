---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import FilterBar from '../../../components/FilterBar.astro';
import PaginatedListing from '../../../components/PaginatedListing.astro';
import { getCollection } from 'astro:content';

const PAGE_SIZE = 30;
const businesses = await getCollection('massage');
businesses.sort((a, b) => (b.data.googleRating || 0) - (a.data.googleRating || 0));
const totalPages = Math.ceil(businesses.length / PAGE_SIZE);
---

<BaseLayout
  title="Barcelona's Best Massage Centers"
  description={`Compare massage centers in Barcelona. Prices, massage types, Google ratings. ${businesses.length} centers.`}
  lang="en"
>
  <section class="max-w-6xl mx-auto px-4 py-12">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-stone-900">Massage in Barcelona</h1>
      <p class="text-stone-500 mt-2">{businesses.length} centers found — compare prices, massage types, and ratings{totalPages > 1 && <span> — page 1 of {totalPages}</span>}</p>
    </div>
    <FilterBar category="massage" lang="en" />
    <PaginatedListing businesses={businesses.slice(0, PAGE_SIZE)} category="massage" lang="en" total={businesses.length} currentPage={1} totalPages={totalPages} />
  </section>
</BaseLayout>
