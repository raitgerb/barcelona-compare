---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="For businesses"
  description="List your nail salon or massage center for free on Barcelona Compare. Reach more clients."
  lang="en"
>
  <div class="max-w-2xl mx-auto px-4 py-16">
    <h1 class="text-3xl font-bold text-stone-900 mb-6">List your business for free</h1>
    <div class="bg-brand-50 rounded-xl border border-brand-100 p-6 mb-8">
      <p class="text-stone-700 leading-relaxed">Own a nail salon or massage center in Barcelona? Add your business for free and reach more clients looking for exactly what you offer.</p>
    </div>
    <div class="space-y-6 text-stone-600">
      <h2 class="text-xl font-semibold text-stone-900">What's included?</h2>
      <ul class="space-y-3">
        <li class="flex gap-3"><span class="text-brand-500 font-bold shrink-0">✓</span><span>Name, address, and contact info</span></li>
        <li class="flex gap-3"><span class="text-brand-500 font-bold shrink-0">✓</span><span>Services and price list</span></li>
        <li class="flex gap-3"><span class="text-brand-500 font-bold shrink-0">✓</span><span>Aggregated Google Maps rating</span></li>
        <li class="flex gap-3"><span class="text-brand-500 font-bold shrink-0">✓</span><span>Hours, languages, and photos</span></li>
        <li class="flex gap-3"><span class="text-brand-500 font-bold shrink-0">✓</span><span>Link to your website, WhatsApp, and phone</span></li>
      </ul>
      <h2 class="text-xl font-semibold text-stone-900 mt-8">How to get listed</h2>
      <p>Email us at <strong>hola@barcelonacompare.com</strong> with your business details and we'll add you. Takes 2-3 business days.</p>
      <p class="text-sm text-stone-400 mt-8">For now, profiles are managed manually. Self-service dashboard coming soon.</p>
    </div>
  </div>
</BaseLayout>
