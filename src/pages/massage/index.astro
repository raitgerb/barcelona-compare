---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FilterBar from '../../components/FilterBar.astro';
import PaginatedListing from '../../components/PaginatedListing.astro';
import { getCollection } from 'astro:content';

const PAGE_SIZE = 30;
const businesses = await getCollection('massage');
businesses.sort((a, b) => (b.data.googleRating || 0) - (a.data.googleRating || 0));
const totalPages = Math.ceil(businesses.length / PAGE_SIZE);
---

<BaseLayout
  title="Los mejores centros de masajes de Barcelona"
  description={`Compara centros de masajes en Barcelona. Precios, tipos de masaje, valoraciones de Google. ${businesses.length} centros.`}
  lang="es"
>
  <section class="max-w-6xl mx-auto px-4 py-12">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-stone-900">Masajes en Barcelona</h1>
      <p class="text-stone-500 mt-2">{businesses.length} centros — compara precios, tipos de masaje y valoraciones{totalPages > 1 && <span> — página 1 de {totalPages}</span>}</p>
    </div>

    <FilterBar category="massage" lang="es" />
    <PaginatedListing businesses={businesses.slice(0, PAGE_SIZE)} category="massage" lang="es" total={businesses.length} currentPage={1} totalPages={totalPages} />
  </section>
</BaseLayout>
