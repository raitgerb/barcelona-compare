---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Lightbox from '../../../components/Lightbox.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const businesses = await getCollection('massage');
  return businesses.map(b => ({ params: { slug: b.id } }));
}

const { slug } = Astro.params;
const businesses = await getCollection('massage');
const business = businesses.find(b => b.id === slug);

if (!business) {
  return Astro.redirect('/massage');
}

const { data } = business;
const stars = data.googleRating ? Math.round(data.googleRating) : 0;
const days = ['monday', 'tuesday', 'wednesday', 'thursday', 'friday', 'saturday', 'sunday'];
const dayLabels: Record<string, string> = {
  monday: 'Lunes', tuesday: 'Martes', wednesday: 'Miércoles', thursday: 'Jueves',
  friday: 'Viernes', saturday: 'Sábado', sunday: 'Domingo',
};

const imagePath = `/images/massage/${slug}`;
const schemaOrg = {
  "@context": "https://schema.org",
  "@type": "BeautySalon",
  "name": data.name,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": data.address,
    "addressLocality": "Barcelona",
    "addressCountry": "ES"
  },
  "telephone": data.phone || undefined,
  "priceRange": data.priceIndicator || undefined,
  ...(data.googleRating && {
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": data.googleRating,
      "reviewCount": data.googleReviewCount
    }
  }),
  ...(data.hours && {
    "openingHoursSpecification": Object.entries(data.hours).map(([day, time]) => {
      const [open, close] = time.split("-");
      return {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": `https://schema.org/${day.charAt(0).toUpperCase() + day.slice(1)}`,
        "opens": open,
        "closes": close
      };
    })
  })
};
---

<BaseLayout
  title={`${data.name} — Masajes en ${data.neighborhood}`}
  description={`${data.name} en ${data.neighborhood}, Barcelona. ${data.googleRating ? `Valoración: ${data.googleRating}/5 (${data.googleReviewCount} reseñas).` : ''}`}
  lang="es"
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)}></script>

  <article class="max-w-3xl mx-auto px-4 py-12">
    <a href="/massage" class="text-sm text-stone-500 hover:text-stone-700 mb-6 inline-block">← Volver a masajes</a>

    <div class="bg-white rounded-xl border border-stone-200 p-6 md:p-8">
      <!-- Photo Gallery -->
      <div class="photo-gallery flex gap-3 mb-8 overflow-x-auto pb-2 snap-x snap-mandatory">
        {[0, 1, 2, 3, 4].map(i => (
          <img
            src={`${imagePath}-${i}.jpg`}
            alt={`${data.name} - foto ${i + 1}`}
            class="snap-start min-w-[280px] h-48 object-cover rounded-xl border border-stone-100"
            loading="lazy"
            onerror="this.style.display='none'"
          />
        ))}
      </div>

      <div class="flex items-start justify-between gap-4 mb-6">
        <div>
          <h1 class="text-2xl font-bold text-stone-900">{data.name}</h1>
          <p class="text-stone-500 mt-1">{data.address}, {data.neighborhood}</p>
          {data.priceIndicator && (
            <span class="inline-block mt-2 text-sm font-medium px-3 py-1 rounded-full bg-stone-100 text-stone-600">{data.priceIndicator}</span>
          )}
        </div>
      </div>

      <div class="flex flex-wrap gap-2 mb-8">
        {data.phone && (
          <a href={`tel:${data.phone}`} class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg bg-stone-900 text-white text-sm font-medium hover:bg-stone-800 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            {data.phone}
          </a>
        )}
        {data.whatsapp && (
          <a href={`https://wa.me/${data.whatsapp.replace(/[^0-9]/g, '')}`} class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg bg-green-600 text-white text-sm font-medium hover:bg-green-700 transition-colors">WhatsApp</a>
        )}
        {data.website && (
          <a href={data.website} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg border border-stone-300 text-stone-700 text-sm font-medium hover:bg-stone-50 transition-colors">Web</a>
        )}
      </div>

      {data.googleRating && (
        <div class="mb-8 p-4 bg-stone-50 rounded-lg">
          <div class="flex items-center gap-2">
            <div class="flex items-center gap-0.5">
              {[1, 2, 3, 4, 5].map(i => (
                <svg class={`w-5 h-5 ${i <= stars ? 'text-amber-400' : 'text-stone-200'}`} fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <span class="text-lg font-bold text-stone-900">{data.googleRating}</span>
            <span class="text-sm text-stone-500">· {data.googleReviewCount} reseñas en Google</span>
          </div>
        </div>
      )}

      {data.massageTypes && data.massageTypes.length > 0 && (
        <section class="mb-8">
          <h2 class="text-lg font-semibold text-stone-900 mb-3">Tipos de masaje</h2>
          <div class="flex flex-wrap gap-2">
            {data.massageTypes.map((t: string) => (
              <span class="text-sm px-3 py-1.5 rounded-full bg-purple-50 text-purple-700 border border-purple-100">{t}</span>
            ))}
          </div>
        </section>
      )}

      {data.services && data.services.length > 0 && (
        <section class="mb-8">
          <h2 class="text-lg font-semibold text-stone-900 mb-3">Servicios y precios</h2>
          <div class="divide-y divide-stone-100">
            {data.services.map((service: any) => (
              <div class="flex justify-between py-2.5">
                <span class="text-stone-700">{typeof service === 'string' ? service : service.name}</span>
                {typeof service !== 'string' && service.price && <span class="font-medium text-stone-900">{service.price}</span>}
              </div>
            ))}
          </div>
        </section>
      )}

      {data.hours && Object.keys(data.hours).length > 0 && (
        <section class="mb-8">
          <h2 class="text-lg font-semibold text-stone-900 mb-3">Horario</h2>
          <div class="divide-y divide-stone-100">
            {days.map(day => {
              const hours = data.hours?.[day];
              if (!hours) return null;
              return (
                <div class="flex justify-between py-2 text-sm">
                  <span class="text-stone-500 w-24">{dayLabels[day]}</span>
                  <span class="text-stone-700">{hours}</span>
                </div>
              );
            })}
          </div>
        </section>
      )}

      {data.languages && data.languages.length > 0 && (
        <section class="mb-8">
          <h2 class="text-lg font-semibold text-stone-900 mb-2">Idiomas</h2>
          <div class="flex flex-wrap gap-2">
            {data.languages.map((lang: string) => (
              <span class="text-sm px-3 py-1 rounded-full bg-stone-100 text-stone-600">{lang}</span>
            ))}
          </div>
        </section>
      )}

      {data.googlePlaceId && (
        <section class="mb-8">
          <h2 class="text-lg font-semibold text-stone-900 mb-3">Ubicación</h2>
          <div class="rounded-lg overflow-hidden border border-stone-200">
            <iframe width="100%" height="300" style="border:0" loading="lazy" allowfullscreen
              referrerpolicy="no-referrer-when-downgrade"
              src={`https://www.google.com/maps/embed/v1/place?key=YOUR_API_KEY&q=place_id:${data.googlePlaceId}`}>
            </iframe>
          </div>
        </section>
      )}

      <div class="mt-8 p-4 bg-brand-50 rounded-lg border border-brand-100 text-center">
        <p class="text-sm text-stone-600">¿Eres el dueño de {data.name}?</p>
        <a href="/for-businesses" class="text-sm font-medium text-brand-600 hover:underline mt-1 inline-block">
          Reclama este negocio →
        </a>
      </div>
    </div>
  </article>
  <Lightbox imagePath={imagePath} photoCount={5} altText={data.name} />
</BaseLayout>
