---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FilterBar from '../../components/FilterBar.astro';
import PaginatedListing from '../../components/PaginatedListing.astro';
import { getCollection } from 'astro:content';

const PAGE_SIZE = 30;
const businesses = await getCollection('nails');
businesses.sort((a, b) => (b.data.googleRating || 0) - (a.data.googleRating || 0));
const totalPages = Math.ceil(businesses.length / PAGE_SIZE);
---

<BaseLayout
  title="Los mejores salones de manicura de Barcelona"
  description={`Compara salones de manicura en Barcelona. Precios, técnicas, valoraciones de Google. ${businesses.length} salones.`}
  lang="es"
>
  <section class="max-w-6xl mx-auto px-4 py-12">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-stone-900">Salones de manicura en Barcelona</h1>
      <p class="text-stone-500 mt-2">{businesses.length} salones — compara precios, técnicas y valoraciones{totalPages > 1 && <span> — página 1 de {totalPages}</span>}</p>
    </div>

    <FilterBar category="nails" lang="es" />
    <PaginatedListing businesses={businesses.slice(0, PAGE_SIZE)} category="nails" lang="es" total={businesses.length} currentPage={1} totalPages={totalPages} />
  </section>
</BaseLayout>
