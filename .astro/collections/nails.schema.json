{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "neighborhood": {
      "type": "string"
    },
    "address": {
      "type": "string"
    },
    "phone": {
      "type": "string"
    },
    "website": {
      "type": "string",
      "format": "uri"
    },
    "whatsapp": {
      "type": "string"
    },
    "priceIndicator": {
      "type": "string",
      "enum": [
        "€",
        "€€",
        "€€€"
      ]
    },
    "services": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "price": {
            "type": "string"
          }
        },
        "required": [
          "name"
        ]
      }
    },
    "hours": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "languages": {
      "default": [
        "Español"
      ],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "googleRating": {
      "type": "number",
      "minimum": 0,
      "maximum": 5
    },
    "googleReviewCount": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "googlePlaceId": {
      "type": "string"
    },
    "photos": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "featured": {
      "default": false,
      "type": "boolean"
    },
    "massageTypes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "name",
    "neighborhood",
    "address"
  ]
}